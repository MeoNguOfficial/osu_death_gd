{
    "geode": "5.4.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "meotn.osudeath_pitch",
    "version": "1.1.0",
    "name": "Osu Death Pitch",
    "developer": "Meo",
    "description": "The music slows down smoothly when you die, just like in osu!",
    "dependencies": {
        "geode.node-ids": ">=v1.20.0"
    },
    "settings": {
        "fade-speed": {
            "name": "Fade Duration",
            "description": "How long it takes for the music to stop (lower = slower).",
            "type": "float",
            "default": 1.0,
            "min": 0.1,
            "max": 5.0,
            "control": {
                "slider": true
            }
        }
    }
}